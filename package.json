{
  "name": "n8n-nodes-userapi",
  "version": "0.1.8",
  "description": "n8n community nodes for UserApi.Ai endpoints",
  "license": "MIT",
  "homepage": "https://userapi.ai",
  "author": {
    "name": "UserAPI",
